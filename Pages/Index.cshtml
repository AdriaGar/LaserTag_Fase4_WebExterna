@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="home-background">
    <div class="hero-overlay"></div>

    <div class="hero">
        <h1>Laser Tag Arena</h1>

        <p>
            Adrenalina, estrategia y combate táctico en tiempo real.
        </p>

        <div class="hero-buttons">
            <a href="/Reservations/Create" class="btn-main">
                Reservar Partida
            </a>

            <a href="/Ranking/Ranking" class="btn-secondary">
                Ver Ranking
            </a>
        </div>
    </div>
</div>

<div class="section-divider"></div>

<section class="info-section">

    <h2>¿Qué es Laser Tag?</h2>

    <p>
        Vive una experiencia de combate táctico en un entorno seguro y lleno de adrenalina.
        Compite con tus amigos, mejora tus habilidades y escala en el ranking global.
    </p>

</section>

<div class="section-divider"></div>

<section class="features">

    <h2 class="section-title">¿Qué puedes hacer?</h2>

    <div class="features-container">

        <div class="feature-card">
            <div class="icon">🎯</div>

            <h3>Combate realista</h3>

            <p>
                Sistemas de juego dinámicos con puntuación en tiempo real.
            </p>
        </div>

        <div class="feature-card">
            <div class="icon">📊</div>

            <h3>Estadísticas</h3>

            <p>
                Consulta tus kills, muertes y rendimiento tras cada partida.
            </p>
        </div>

        <div class="feature-card">
            <div class="icon">🏆</div>

            <h3>Ranking global</h3>

            <p>
                Compite contra otros jugadores y alcanza el top.
            </p>
        </div>

    </div>

</section>

<div class="section-divider"></div>

<section class="modes-section">

    <h2 class="section-title">Modos de juego</h2>

    <div class="modes-container">

        <div class="mode-card">

            <div class="mode-info">

                <div class="mode-icon">🎯</div>

                <h3>Todos contra todos</h3>

                <p>
                    El jugador con más puntos al final gana la partida.
                </p>

            </div>
        </div>

        <div class="mode-card">

            <div class="mode-info">

                <div class="mode-icon">🛡️</div>

                <h3>Por equipos</h3>

                <p>
                    Coordínate con tu escuadrón y domina la arena.
                </p>

            </div>
        </div>

        <div class="mode-card">

            <div class="mode-info">

                <div class="mode-icon">🚩</div>

                <h3>Atrapa la bandera</h3>

                <p>
                    Infiltración, estrategia y máxima tensión.
                </p>

            </div>
        </div>

    </div>

</section>

<div class="section-divider"></div>

<section class="why-section">

    <h2 class="section-title">
        ¿Por qué elegir Laser Tag Arena?
    </h2>

    <div class="why-container">

        <div class="why-box">
            <span>⚡</span>
            <h3>Equipamiento profesional</h3>
        </div>

        <div class="why-box">
            <span>🛡️</span>
            <h3>Entornos tácticos inmersivos</h3>
        </div>

        <div class="why-box">
            <span>🎮</span>
            <h3>Modos de juego dinámicos</h3>
        </div>

        <div class="why-box">
            <span>🏆</span>
            <h3>Sistema de ranking competitivo</h3>
        </div>

    </div>
        
</section>

<div class="section-divider"></div>

<section class="cta-section">

    <div class="cta-box">

        <h2>¿Preparado para entrar en combate?</h2>

        <p>
            Reserva tu partida ahora y demuestra quién domina la arena.
        </p>

        <a href="/Reservations/Create" class="btn-main">
            Reservar ahora
        </a>

    </div>

</section>