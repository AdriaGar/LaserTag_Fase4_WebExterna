@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="home-background">
    <div class="hero-overlay"></div>

    <div class="hero">
        <h1>Laser Tag Arena</h1>
        <p>Adrenalina, estrategia y combate en tiempo real.</p>

        <div class="hero-buttons">
            <a href="/Reservations/Create" class="btn-main">Reservar Partida</a>
            <a href="/Ranking" class="btn-secondary">Ver Ranking</a>
        </div>
    </div>
</div></div>

<section class="info-section">
    <h2>¿Qué es Laser Tag?</h2>
    <p>
        Vive una experiencia de combate táctico en un entorno seguro y lleno de adrenalina.
        Compite con tus amigos, mejora tus habilidades y escala en el ranking global.
    </p>
</section>

<section class="features">
    <h2 class="section-title">¿Qué puedes hacer?</h2>

    <div class="features-container">

        <div class="feature-card">
            <div class="icon">🎯</div>
            <h3>Combate realista</h3>
            <p>Sistemas de juego dinámicos con puntuación en tiempo real.</p>
        </div>

        <div class="feature-card">
            <div class="icon">📊</div>
            <h3>Estadísticas</h3>
            <p>Consulta tus kills, muertes y rendimiento tras cada partida.</p>
        </div>

        <div class="feature-card">
            <div class="icon">🏆</div>
            <h3>Ranking global</h3>
            <p>Compite contra otros jugadores y alcanza el top.</p>
        </div>

    </div>
</section>

<section class="stats">
    <h2 class="section-title">Actividad en la arena</h2>

    <div class="stats-container">

        <div class="stat-card">
            <h3>1500+</h3>
            <p>Partidas jugadas</p>
        </div>

        <div class="stat-card">
            <h3>300+</h3>
            <p>Jugadores activos</p>
        </div>

        <div class="stat-card">
            <h3>12000+</h3>
            <p>Kills registradas</p>
        </div>

    </div>
</section>