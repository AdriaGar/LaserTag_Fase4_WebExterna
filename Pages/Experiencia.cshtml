@page
@{
    ViewData["Title"] = "La experiencia Laser Tag";
}

<div class="experience-background">

    <div class="experience-container">

        <h1 class="experience-title">La experiencia Laser Tag</h1>
        <p class="experience-subtitle">
            Vive una experiencia única llena de acción, estrategia y adrenalina.
            Perfecto para amigos, cumpleaños y eventos especiales.
        </p>

        <div class="experience-grid">

            <div class="experience-card">
                <h3>🔥 Acción real</h3>
                <p>
                    Sumérgete en una batalla inmersiva con luces, sonidos y escenarios
                    diseñados para una experiencia totalmente realista.
                </p>
            </div>

            <div class="experience-card">
                <h3>🎯 Estrategia y equipo</h3>
                <p>
                    Juega en equipo, planea tu estrategia y coopera para alcanzar la victoria
                    en nuestros modos de juego.
                </p>
            </div>

            <div class="experience-card">
                <h3>🏆 Para todos</h3>
                <p>
                    Ideal para todas las edades: grupos de amigos, familias, cumpleaños
                    y eventos de empresa.
                </p>
            </div>

            <div class="experience-card">
                <h3>⏱️ Partidas dinámicas</h3>
                <p>
                    Partidas rápidas, intensas y totalmente personalizables según el número
                    de jugadores.
                </p>
            </div>

        </div>

    </div>

</div>