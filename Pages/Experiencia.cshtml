@page
@{
    ViewData["Title"] = "La experiencia Laser Tag";
}

<div class="experience-hero">

    <div class="experience-overlay"></div>

    <div class="experience-container">

        <div class="experience-top">

            <span class="experience-badge">
                EXPERIENCIA INMERSIVA
            </span>

            <h1 class="experience-title">
                Entra en combate.
            </h1>

            <p class="experience-subtitle">
                Vive partidas tácticas llenas de adrenalina, estrategia y acción en tiempo real.
                Un entorno diseñado para hacerte sentir dentro de una auténtica operación militar.
            </p>

            <div class="experience-buttons">

                <a href="/Reservations/Create" class="btn-main">
                    Reservar Partida
                </a>

                <a href="/Ranking/Ranking" class="btn-secondary">
                    Ver Ranking
                </a>

            </div>

        </div>

    </div>

</div>

<div class="section-divider"></div>

<section class="experience-section">

    <div class="experience-container">

        <h2 class="experience-section-title">
            ¿Qué hace única la experiencia?
        </h2>

        <div class="experience-grid">

            <div class="experience-card">
                <div class="experience-icon">🔥</div>

                <h3>Acción cinematográfica</h3>

                <p>
                    Luces dinámicas, humo ambiental y escenarios tácticos
                    para una experiencia totalmente inmersiva.
                </p>
            </div>

            <div class="experience-card">
                <div class="experience-icon">🎯</div>

                <h3>Estrategia en equipo</h3>

                <p>
                    Coordínate con tu escuadrón, protege posiciones
                    y domina cada partida.
                </p>
            </div>

            <div class="experience-card">
                <div class="experience-icon">⚡</div>

                <h3>Partidas intensas</h3>

                <p>
                    Ritmo rápido, combates constantes y adrenalina
                    desde el primer minuto.
                </p>
            </div>

            <div class="experience-card">
                <div class="experience-icon">🏆</div>

                <h3>Competición real</h3>

                <p>
                    Sistema de ranking, estadísticas y modos competitivos
                    para demostrar quién manda.
                </p>
            </div>

        </div>

    </div>

</section>

<div class="section-divider"></div>



<div class="section-divider"></div>

<section class="cta-section">

    <div class="cta-box">

        <h2>¿Preparado para entrar en combate?</h2>

        <p>
            Reserva tu partida ahora y demuestra quién domina la arena.
        </p>

        <a href="/Reservations/Create" class="btn-main">
            Reservar ahora
        </a>

    </div>

</section>