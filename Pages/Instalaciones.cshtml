@page
@{
    ViewData["Title"] = "Instalaciones";
}

<!-- HERO -->

<section class="instalaciones-hero">

    <div class="instalaciones-overlay"></div>

    <div class="instalaciones-hero-content">

        <span class="instalaciones-badge">
            LASER TAG ARENA
        </span>

        <h1>
            Nuestras instalaciones
        </h1>

        <p>
            Escenarios tácticos inmersivos, iluminación profesional y arenas
            diseñadas para ofrecer una experiencia de combate única.
        </p>

    </div>

</section>

<div class="section-divider"></div>

<!-- INSTALACIONES -->

<section class="instalaciones-section">

    <!-- SALA 1 -->

    <div class="instalacion-card">

        <div class="instalacion-image">

            <img src="/images/Instalacion1.png" alt="Sala 1">

        </div>

        <div class="instalacion-info">

            <span class="instalacion-tag">
                ARENA TÁCTICA
            </span>

            <h2>Sala número 1</h2>

            <p class="instalacion-description">
                Un entorno cerrado diseñado para partidas rápidas y estratégicas,
                ideal para combates intensos 5 vs 5.
            </p>

            <div class="instalacion-stats">

                <div class="instalacion-stat">
                    <h3>5 vs 5</h3>
                    <p>Jugadores</p>
                </div>

                <div class="instalacion-stat">
                    <h3>2:53</h3>
                    <p>Duración media</p>
                </div>

                <div class="instalacion-stat">
                    <h3>30 / 20</h3>
                    <p>Resultados</p>
                </div>

            </div>

        </div>

    </div>

    <!-- SALA 2 -->

    <div class="instalacion-card reverse">

        <div class="instalacion-image">

            <img src="/images/Instalacion2.png" alt="Sala 2">

        </div>

        <div class="instalacion-info">

            <span class="instalacion-tag">
                COMBATE MASIVO
            </span>

            <h2>Sala número 2</h2>

            <p class="instalacion-description">
                Arena de gran tamaño preparada para partidas dinámicas con equipos
                numerosos y múltiples zonas tácticas.
            </p>

            <div class="instalacion-stats">

                <div class="instalacion-stat">
                    <h3>10 vs 10</h3>
                    <p>Jugadores</p>
                </div>

                <div class="instalacion-stat">
                    <h3>5:25</h3>
                    <p>Duración media</p>
                </div>

                <div class="instalacion-stat">
                    <h3>20 / 65</h3>
                    <p>Resultados</p>
                </div>

            </div>

        </div>

    </div>

</section>

<div class="section-divider"></div>

<!-- CTA -->

<section class="instalaciones-cta">

    <div class="instalaciones-cta-box">

        <h2>
            ¿Preparado para entrar en combate?
        </h2>

        <p>
            Reserva ahora tu partida y vive la experiencia definitiva de Laser Tag.
        </p>

        <a href="/Reservations/Create" class="btn-main">
            Reservar partida
        </a>

    </div>

</section>