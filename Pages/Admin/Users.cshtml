@page
@model Fase4_WebExterna.Pages.Admin.UsersModel

<div class="admin-page">

    <h1>👥 Gestión de Usuarios</h1>

    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Usuarios)
            {
                <tr>
                    <td>@u.IdJugador</td>
                    <td>@u.Nom @u.Cognoms</td>
                    <td>@u.Email</td>
                    <td>@u.Rol</td>
                    <td>

                        <!-- ❌ ELIMINAR -->
                        <form method="post" asp-page-handler="Delete"
                              onsubmit="return confirm('¿Eliminar usuario?');">
                            <input type="hidden" name="id" value="@u.IdJugador" />
                            <button type="submit" class="btn-delete">❌</button>
                        </form>

                        <!-- 🔁 CAMBIAR ROL -->
                        <form method="post" asp-page-handler="ToggleRole">
                            <input type="hidden" name="id" value="@u.IdJugador" />

                            @if (u.Rol == "Admin")
                            {
                                <button type="submit" class="btn-role demote">
                                    ↓ User
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn-role promote">
                                    ↑ Admin
                                </button>
                            }
                        </form>

                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>