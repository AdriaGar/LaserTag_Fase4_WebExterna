@page
@model Fase4_WebExterna.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="profile-background">
    <div class="profile-container">

        <h1 class="profile-title">Mi Perfil</h1>

        <!-- CARD PERFIL -->
        <div class="profile-card">

            <!-- Avatar -->
            <div class="profile-avatar">
                <img src="/images/MilitarBackground.jpg" alt="Avatar">
            </div>

            <!-- Info -->
            <div class="profile-info">
                <p><strong>Nombre:</strong> @Model.Jugador?.Nom</p>
                <p><strong>Cognoms:</strong> @Model.Jugador?.Cognoms</p>
                <p><strong>Email:</strong> @Model.Jugador?.Email</p>
                <p><strong>Fecha de registro:</strong> @Model.Jugador?.DataRegistre</p>

                <div class="profile-actions">
                    <a asp-page="/Account/EditProfile" class="edit">Editar datos</a>
                    <a asp-page="/Account/ChangePassword" class="edit">Cambiar contraseña</a>
                    <a asp-page="/Account/Logout" class="danger">Cerrar sesión</a>
                </div>
            </div>

        </div>

        <!-- RESERVAS -->
        <h2 class="profile-subtitle">Mis Reservas</h2>

        @if (Model.Reserves == null || !Model.Reserves.Any())
        {
            <p>No tienes reservas realizadas.</p>
        }
        else
        {
            <div class="reservations-grid">
                @foreach (var r in Model.Reserves)
                {
                    var partida = r.IdPartidaNavigation;

                    <div class="reservation-card">

                        <div class="reservation-header">
                            📅 @r.DataReserva &nbsp;&nbsp; 🕒 @r.HoraReserva - @partida?.DataFi?.Split(" ")[1]
                        </div>

                        <p>🎮 <strong>Modo:</strong> @partida?.ModeJoc</p>
                        <p>🔵 <strong>Estado:</strong> @r.EstatReserva</p>

                        <form method="post" asp-page-handler="Cancel" onsubmit="return confirmarCancelacion();">
                            <input type="hidden" name="idReserva" value="@r.IdReserva" />
                            <button type="submit" class="btn-cancel">
                                Cancelar reserva
                            </button>
                        </form>
                    </div>
                }
            </div>
        }

        <!-- ESTADÍSTICAS DEL JUGADOR -->

        <h2 class="profile-subtitle">Mis Estadísticas</h2>

        @if (Model.Estadisticas != null)
        {
            <div class="stats-container">

                <div class="stat-card">
                    <h3>@Model.Estadisticas.resumen.partides_jugades</h3>
                    <p>Partidas Jugadas</p>
                </div>

                <div class="stat-card">
                    <h3>@Model.Estadisticas.resumen.total_kills</h3>
                    <p>Kills</p>
                </div>

                <div class="stat-card">
                    <h3>@Model.Estadisticas.resumen.total_morts</h3>
                    <p>Muertes</p>
                </div>

                <div class="stat-card">
                    <h3>@Model.Estadisticas.resumen.total_punts</h3>
                    <p>Puntos</p>
                </div>

            </div>
        }
        else
        {
            <p>No hay estadísticas disponibles.</p>
        }

        <!-- HISTORIAL DE PARTIDAS -->

        <h2 class="profile-subtitle">Historial de Partidas</h2>

        @if (Model.Estadisticas != null && Model.Estadisticas.historial != null && Model.Estadisticas.historial.Any())
        {
            <table class="history-table">

                <thead>
                    <tr>
                        <th>Partida</th>
                        <th>Puntos</th>
                        <th>Kills</th>
                        <th>Muertes</th>
                        <th>Posición</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var partida in Model.Estadisticas.historial)
                    {
                        <tr>
                            <td>@partida.id_partida</td>
                            <td>@partida.punts</td>
                            <td>@partida.kills</td>
                            <td>@partida.morts</td>
                            <td>@partida.posicio</td>
                        </tr>
                    }

                </tbody>

            </table>
        }
        else
        {
            <p>No hay partidas registradas.</p>
        }

    </div>
</div>

@section Scripts {
    <script>
        function confirmarCancelacion() {
            return confirm("¿Seguro que deseas cancelar esta reserva?");
        }
    </script>
}