@page
@model Fase4_WebExterna.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar contraseña";
}

<div class="edit-profile-background">
    <div class="edit-profile-card">

        <h1>Cambiar contraseña</h1>

        <form method="post" class="edit-profile-form">

            <div class="form-group">
                <label>Contraseña actual</label>
                <input asp-for="Input.ContraseñaActual" type="password" />
            </div>

            <div class="form-group">
                <label>Nueva contraseña</label>
                <input asp-for="Input.NuevaContraseña" type="password" />
            </div>

            <div class="form-group">
                <label>Confirmar nueva contraseña</label>
                <input asp-for="Input.ConfirmarContraseña" type="password" />
            </div>

            <button type="submit" class="btn-save">
                Guardar cambios
            </button>

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <p class="success-message">@Model.SuccessMessage</p>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <p class="error-message">@Model.ErrorMessage</p>
            }

        </form>

    </div>
</div>