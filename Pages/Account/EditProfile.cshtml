@page
@model Fase4_WebExterna.Pages.Account.EditProfileModel
@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="edit-profile-background">
    <div class="edit-profile-card">

        <h1>Editar Perfil</h1>

        <form method="post" class="edit-profile-form">

            <div class="form-group">
                <label>Nombre</label>
                <input asp-for="Input.Nom" />
            </div>

            <div class="form-group">
                <label>Cognoms</label>
                <input asp-for="Input.Cognoms" />
            </div>

            <button type="submit" class="btn-save">
                Guardar cambios
            </button>

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <p class="success-message">@Model.SuccessMessage</p>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <p class="error-message">@Model.ErrorMessage</p>
            }

        </form>

    </div>
</div>